<% turbo_refreshes_with method: :morph, scroll: :preserve %>

<div class="space-y-8">
  <div class="text-center">
    <h1 class="text-4xl font-bold text-gray-900 tracking-tight">Todos</h1>
    <p class="mt-2 text-gray-500">A Rails 8 + Hotwire demo with Turbo Morphing &amp; View Transitions</p>
  </div>

  <%# New todo form %>
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4">
    <%= form_with model: @todo, url: todos_path, class: "flex items-center gap-3" do |f| %>
      <%= f.text_field :name,
        placeholder: "What needs to be done?",
        autofocus: true,
        class: "flex-1 rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-gray-900 placeholder-gray-400 px-4 py-2.5" %>
      <%= f.submit "Add",
        class: "inline-flex items-center rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition-colors cursor-pointer" %>
    <% end %>
  </div>

  <% if flash[:alert].present? %>
    <div class="rounded-lg bg-red-50 border border-red-200 p-3 text-sm text-red-700">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%# Active todos %>
  <div id="active-todos">
    <% if @active_todos.any? %>
      <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">
        Active &middot; <%= @active_todos.size %>
      </h2>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 divide-y divide-gray-100">
        <% @active_todos.each do |todo| %>
          <%= render todo %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Completed todos %>
  <div id="completed-todos">
    <% if @completed_todos.any? %>
      <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3 mt-6" style="view-transition-name: completed-heading; view-transition-class: todo">
        Completed &middot; <%= @completed_todos.size %>
      </h2>
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 divide-y divide-gray-100">
        <% @completed_todos.each do |todo| %>
          <%= render todo %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @active_todos.empty? && @completed_todos.empty? %>
    <div class="text-center py-12 text-gray-400">
      <svg class="mx-auto h-12 w-12 mb-4" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
      </svg>
      <p class="text-lg font-medium">No todos yet</p>
      <p class="mt-1">Add one above to get started</p>
    </div>
  <% end %>
</div>
